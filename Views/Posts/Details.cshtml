@model BlogApp.Models.Post

@{
    ViewData["Title"] = "Post Details";
}

<h2>@Model.Title</h2>
<hr />

<dl class="row">
    <dt class="col-sm-2">
        @Html.DisplayNameFor(model => model.Body)
    </dt>
    <dd class="col-sm-10">
        @Html.DisplayFor(model => model.Body)
    </dd>

    <dt class="col-sm-2">
        @Html.DisplayNameFor(model => model.CreatedAt)
    </dt>
    <dd class="col-sm-10">
        @Html.DisplayFor(model => model.CreatedAt)
    </dd>

    <dt class="col-sm-2">
        @Html.DisplayNameFor(model => model.Category)
    </dt>
    <dd class="col-sm-10">
        @Html.DisplayFor(model => model.Category.Name)
    </dd>
</dl>

<a asp-action="Edit" asp-route-id="@Model.PostID">Edit</a> |
<a asp-action="Index">Back to List</a>

<hr />

@* ─── COMMENTS SECTION ─── *@

<h4>Comments (@Model.Comments.Count)</h4>

@if (Model.Comments.Any())
{
    foreach (var comment in Model.Comments)
    {
        <div style="border: 1px solid #ddd; padding: 10px; margin-bottom: 10px; border-radius: 4px;">
            <strong>@comment.AuthorName</strong>
            <small style="color: gray; margin-left: 10px;">@comment.CreatedAt.ToString("MMM dd, yyyy HH:mm")</small>
            <p>@comment.Body</p>

            <form asp-controller="Comments" asp-action="Delete" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@comment.CommentID" />
                <button type="submit">Delete</button>
            </form>
        </div>
    }
}
else
{
    <p style="color: gray;">No comments yet. Be the first to comment!</p>
}

<hr />

@* ─── ADD COMMENT FORM ─── *@

<h4>Leave a Comment</h4>

<form asp-controller="Comments" asp-action="Create" method="post">
    @Html.AntiForgeryToken()

    <input type="hidden" name="PostId" value="@Model.PostID" />

    <div class="mb-3">
        <label asp-for="@(new BlogApp.Models.Comment().AuthorName)" class="form-label">Your Name</label>
        <input type="text" name="AuthorName" class="form-control" />
        <span class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="@(new BlogApp.Models.Comment().Body)" class="form-label">Comment</label>
        <textarea name="Body" class="form-control" rows="3"></textarea>
        <span class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Post Comment</button>
</form>
